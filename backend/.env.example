# Backend environment variables
# Copy this file to .env and fill in the values

# MongoDB connection string (local)
MONGODB_URI=mongodb://localhost:27017/yt-comments-analyzer

# Redis connection (local)
REDIS_HOST=localhost
REDIS_PORT=6379

# Server port
PORT=5001

# YouTube Data API v3 key (create at Google Cloud Console)
YOUTUBE_API_KEY=your_youtube_api_key_here

# AI service URL (Python FastAPI microservice)
AI_SERVICE_URL=http://localhost:8000

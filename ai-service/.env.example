# AI service environment variables
# Copy this file to .env and fill in the values

# Groq API key (free tier — sign up at groq.com)
GROQ_API_KEY=your_groq_api_key_here

# LLM provider (currently only "groq")
LLM_PROVIDER=groq

# LLM model name
LLM_MODEL=llama-3.1-8b-instant

# Sentiment model — configurable (DistilBERT or RoBERTa)
# Pre-trained baseline before fine-tuning:
SENTIMENT_MODEL_NAME=distilbert-base-uncased-finetuned-sst-2-english
# After fine-tuning (Phase 5), replace with path to fine-tuned model:
# SENTIMENT_MODEL_NAME=./training/checkpoints/fine-tuned-distilbert

# Zero-shot classification model (for aspect-based sentiment + intent)
# Distilled MNLI model (~260MB) — smaller alternative to bart-large-mnli (1.63GB)
ZEROSHOT_MODEL_NAME=typeform/distilbert-base-uncased-mnli

# Toxicity detection model (pre-trained)
TOXICITY_MODEL_NAME=unitary/toxic-bert

# Sentence transformer for embeddings + BERTopic
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# FAISS index storage directory
FAISS_INDEX_DIR=./data/faiss

# Server settings
AI_SERVICE_PORT=8000
